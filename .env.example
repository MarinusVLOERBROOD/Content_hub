# ── Verplicht ─────────────────────────────────────────────────────────────────
# Minimaal 32 willekeurige tekens. Genereer met: openssl rand -base64 32
SESSION_SECRET=verander-dit-naar-een-willekeurige-string-van-minimaal-32-tekens

# ── Database ───────────────────────────────────────────────────────────────────
# Lokaal: file:./content-hub.db
# Railway (met Volume gemount op /data): file:/data/content-hub.db
DATABASE_URL=file:./content-hub.db

# ── Bestanden (uploads) ────────────────────────────────────────────────────────
# Lokaal: ./uploads
# Railway (met Volume gemount op /data): /data/uploads
UPLOAD_DIR=./uploads

# ── App URL ────────────────────────────────────────────────────────────────────
# Lokaal: http://localhost:3000
# Railway: https://<jouw-app>.railway.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Railway deployment checklist ──────────────────────────────────────────────
# 1. Voeg een Volume toe in Railway dashboard (Mount Path: /data)
# 2. Stel bovenstaande variabelen in als Railway environment variables
# 3. Na de EERSTE deploy eenmalig uitvoeren via Railway console:
#      npm run db:setup
#    (maakt tabellen aan + laadt demo-data; daarna niet meer nodig)
# 4. Bij latere deploys draait railway.toml automatisch: npm run db:migrate
