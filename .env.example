# ── .env.local (niet committen) ──────────────────────────────────────────────
# Verplicht: minimaal 32 willekeurige tekens, gebruik bijv. `openssl rand -base64 32`
SESSION_SECRET=verander-dit-naar-een-willekeurige-string-van-minimaal-32-tekens

# Optioneel – standaard http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optioneel – standaard ./uploads
UPLOAD_DIR=./uploads

# ── .env (mag gecommit worden) ───────────────────────────────────────────────
# Verplicht voor prisma migrate / seed commando's (dotenv/config leest .env.local niet)
DATABASE_URL=file:./content-hub.db
